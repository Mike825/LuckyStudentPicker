<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="LuckyStudentPicker.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LuckyStudentPicker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SettingsWindow"
    >
    <Window.SystemBackdrop>
        <MicaBackdrop></MicaBackdrop>
    </Window.SystemBackdrop>
    
    <Grid>
        <Grid x:Name="SettingsTitleBar" Grid.Column="0" Grid.Row="0">
            <Image Source="/Assets/program.ico"
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top"
                   Width="20" Height="20" 
                   Margin="16,16"
                   Grid.Column="0"/>

            <TextBlock x:Name="AppTitleTextBlock" Text="Settings"
                       TextWrapping="NoWrap"
                       FontSize="20"
                       VerticalAlignment="Top"
                       Margin="48,10,28,28"
                       Grid.Column="1"/>
        </Grid>

        <NavigationView x:Name="SettingsNV" Margin="0, 48, 0, 0" IsBackButtonVisible="Collapsed" IsSettingsVisible="False" IsPaneOpen="False" ItemInvoked="SettingsNV_ItemInvoked" Loaded="SettingsNV_Loaded">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="Home" Tag="HomePage" />
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="About" Tag="AboutPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
