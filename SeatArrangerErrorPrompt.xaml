<ContentDialog
    x:Class="LuckyStudentPicker.SeatArrangerErrorPrompt"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LuckyStudentPicker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Wrong Operation"
    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
    Style="{StaticResource DefaultContentDialogStyle}"
    CornerRadius="8"
    PrimaryButtonText="Cancel"
    PrimaryButtonClick="SeatArrangerErrorPrompt_PrimaryButtonClick"
>

    <Grid>
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Something wrong has happened and SeatArranger won't function properly. " TextWrapping="WrapWholeWords" ></TextBlock>
            <TextBlock Text="This is a beta version, so some problems may be fixed later on. " TextWrapping="WrapWholeWords" ></TextBlock>
        </StackPanel>
    </Grid>
</ContentDialog>
